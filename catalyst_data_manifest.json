{
  "name": "Catalyst Data",
  "version": "1.3.0",
  "module_type": "sources, provenance, and evidence chain",
  "record_contract": "catalyst-data-record/1.0",
  "record_schema": "schemas/catalyst_data_record_1_0.schema.json",
  "review_contract": "contracts/review_contract.json",
  "method_path": [
    "entity",
    "indicator",
    "period",
    "measurement",
    "evidence chain",
    "confidence",
    "review"
  ],
  "wordpress_shortcode": "[catalyst_data_demo]",
  "repository": "https://github.com/Content-Catalyst-LLC/catalyst-data",
  "boundaries": [
    "educational",
    "open-source",
    "not compliance certification",
    "not professional advice"
  ],
  "release": "Sources, Provenance, and Evidence Chain",
  "version_source": "VERSION",
  "generated_contract_artifacts": [
    "python/catalyst_data/_contract.py",
    "python/catalyst_data/_record_contract.py",
    "python/catalyst_data/_version.py",
    "python/catalyst_data/schemas/catalyst_data_record_1_0.schema.json",
    "schemas/catalyst_data_record_1_0.schema.json",
    "wordpress/catalyst-data-demo/assets/catalyst-data-contract.js",
    "wordpress/catalyst-data-demo/assets/catalyst-data-record-contract.js",
    "schema.sql review views"
  ],
  "legacy_upgrade": "catalyst-data upgrade INPUT.json OUTPUT.json",
  "validation_command": "catalyst-data validate RECORD.json",
  "build_command": "python3 scripts/build_release.py",
  "release_validation_command": "python3 scripts/check_release.py",
  "database": "SQLite",
  "migration_path": "python/catalyst_data/migrations",
  "repository_commands": [
    "init",
    "migrate",
    "rollback",
    "status",
    "import",
    "export",
    "inspect",
    "review",
    "sources",
    "provenance",
    "evidence"
  ],
  "import_formats": [
    "json",
    "csv"
  ],
  "initialization_command": "catalyst-data init catalyst-data.sqlite3",
  "import_command": "catalyst-data import catalyst-data.sqlite3 records.json",
  "export_command": "catalyst-data export catalyst-data.sqlite3 records.json",
  "evidence_contract": "catalyst-data-evidence-chain/1.0",
  "evidence_schema": "schemas/catalyst_data_evidence_chain_1_0.schema.json"
}
