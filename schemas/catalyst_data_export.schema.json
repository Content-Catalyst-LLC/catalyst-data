{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-data-export-1.0.1.json",
  "title": "Catalyst Data Export",
  "description": "Catalyst Data v1.0.1 traceable measurement export.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entity",
    "indicator",
    "period",
    "values",
    "source",
    "confidence",
    "review_status",
    "signal_status",
    "trace_path"
  ],
  "properties": {
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "country",
            "organization",
            "project",
            "program",
            "site",
            "policy",
            "persona",
            "experiment",
            "dataset",
            "other"
          ]
        }
      }
    },
    "indicator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "unit",
        "direction"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "enum": [
            "higher",
            "lower",
            "neutral"
          ]
        }
      }
    },
    "period": {
      "type": "string",
      "minLength": 1
    },
    "values": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseline",
        "current",
        "percent_change"
      ],
      "properties": {
        "baseline": {
          "type": "number"
        },
        "current": {
          "type": "number"
        },
        "percent_change": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "review_status": {
      "enum": [
        "missing source",
        "needs evidence",
        "reviewable with caution",
        "reviewable"
      ]
    },
    "signal_status": {
      "enum": [
        "indeterminate",
        "improving",
        "declining",
        "unchanged",
        "descriptive"
      ]
    },
    "method_notes": {
      "type": "string"
    },
    "trace_path": {
      "type": "array",
      "prefixItems": [
        {
          "const": "entity"
        },
        {
          "const": "indicator"
        },
        {
          "const": "period"
        },
        {
          "const": "measurement"
        },
        {
          "const": "source"
        },
        {
          "const": "confidence"
        },
        {
          "const": "review"
        }
      ],
      "items": false,
      "minItems": 7,
      "maxItems": 7
    }
  }
}
