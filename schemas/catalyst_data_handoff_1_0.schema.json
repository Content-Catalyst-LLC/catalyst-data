{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-data-handoff-1.0.schema.json",
  "title": "Catalyst Data Platform Handoff 1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "handoff_id", "created_at", "source", "target", "action", "records", "context"],
  "properties": {
    "schema_version": {"const": "catalyst-data-handoff/1.0"},
    "handoff_id": {"type": "string", "pattern": "^handoff:[a-z0-9][a-z0-9._:-]{7,127}$"},
    "created_at": {"type": "string", "format": "date-time"},
    "source": {"$ref": "#/$defs/productEndpoint"},
    "target": {"$ref": "#/$defs/productEndpoint"},
    "action": {"enum": ["record-reference", "record-transfer", "query-run-reference", "export-bundle-reference"]},
    "records": {"type": "array", "items": {"$ref": "#/$defs/recordReference"}, "uniqueItems": true},
    "query_run_id": {"type": ["string", "null"]},
    "bundle_uri": {"type": ["string", "null"], "format": "uri-reference"},
    "context": {"type": "object"},
    "extensions": {"type": "object", "propertyNames": {"pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)+$"}}
  },
  "$defs": {
    "productEndpoint": {
      "type": "object", "additionalProperties": false,
      "required": ["product", "version", "component", "capability"],
      "properties": {
        "product": {"enum": ["catalyst-data", "knowledge-library", "research-librarian", "site-intelligence", "workbench", "research-lab", "catalyst-analytics-r", "catalyst-canvas", "decision-studio", "platform-core"]},
        "version": {"type": "string", "minLength": 1},
        "component": {"type": "string", "minLength": 1},
        "capability": {"type": "string", "minLength": 1}
      }
    },
    "recordReference": {
      "type": "object", "additionalProperties": false,
      "required": ["record_id", "record_sha256", "href"],
      "properties": {
        "record_id": {"type": "string", "minLength": 3},
        "record_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "href": {"type": ["string", "null"], "format": "uri-reference"}
      }
    }
  }
}
