{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-data-indicator-governance-1.0.json",
  "title": "Catalyst Data Indicator Governance 1.0",
  "description": "Versioned indicator definitions, units, methodologies, mappings, and comparability constraints.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "namespace",
    "code",
    "domain",
    "custodian",
    "status",
    "aliases",
    "definition",
    "frequency",
    "aggregation",
    "disaggregation_dimensions",
    "numerator",
    "denominator",
    "unit",
    "methodology",
    "framework_mappings",
    "compatibility"
  ],
  "properties": {
    "schema_version": {
      "const": "catalyst-data-indicator-governance/1.0"
    },
    "namespace": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9.-]{1,63}$"
    },
    "code": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{1,127}$"
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "custodian": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "draft",
        "active",
        "deprecated",
        "replaced",
        "archived"
      ]
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "definition": {
      "type": "string",
      "minLength": 1
    },
    "frequency": {
      "enum": [
        "continuous",
        "daily",
        "weekly",
        "monthly",
        "quarterly",
        "annual",
        "irregular",
        "event",
        "custom"
      ]
    },
    "aggregation": {
      "enum": [
        "sum",
        "mean",
        "median",
        "minimum",
        "maximum",
        "count",
        "ratio",
        "index",
        "point-estimate",
        "cumulative",
        "custom"
      ]
    },
    "disaggregation_dimensions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "numerator": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "name",
        "unit_id",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "unit_id": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "denominator": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "name",
        "unit_id",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "unit_id": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "unit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "symbol",
        "name",
        "dimension",
        "canonical_unit_id",
        "conversion_factor",
        "conversion_offset"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
        },
        "symbol": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "dimension": {
          "type": "string",
          "minLength": 1
        },
        "canonical_unit_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
        },
        "conversion_factor": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "conversion_offset": {
          "type": "number"
        }
      }
    },
    "methodology": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "title",
        "description",
        "formula",
        "references",
        "status",
        "approved_by",
        "approved_at",
        "revision_notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "formula": {
          "type": [
            "string",
            "null"
          ]
        },
        "references": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "status": {
          "enum": [
            "draft",
            "in-review",
            "approved",
            "deprecated",
            "archived"
          ]
        },
        "approved_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "approved_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "revision_notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "framework_mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "framework",
          "code",
          "relationship",
          "notes"
        ],
        "properties": {
          "framework": {
            "type": "string",
            "minLength": 1
          },
          "code": {
            "type": "string",
            "minLength": 1
          },
          "relationship": {
            "enum": [
              "exactMatch",
              "closeMatch",
              "broaderMatch",
              "narrowerMatch",
              "relatedMatch"
            ]
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "comparable_versions",
        "required_dimensions",
        "methodology_equivalence",
        "notes"
      ],
      "properties": {
        "comparable_versions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "required_dimensions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "methodology_equivalence": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
          },
          "uniqueItems": true
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
