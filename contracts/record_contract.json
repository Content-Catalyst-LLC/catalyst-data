{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/contracts/catalyst-data-record-contract-1.0.json",
  "contract": "catalyst-data-record/1.0",
  "schema_file": "schemas/catalyst_data_record_1_0.schema.json",
  "record_types": [
    "measurement"
  ],
  "entity_types": [
    "country",
    "organization",
    "project",
    "program",
    "site",
    "policy",
    "persona",
    "experiment",
    "dataset",
    "other"
  ],
  "source_types": [
    "internal record",
    "third-party dataset",
    "survey",
    "public registry",
    "model estimate",
    "publication",
    "sensor",
    "api",
    "other",
    "unspecified"
  ],
  "producer_components": [
    "python-engine",
    "browser-demo",
    "migration-tool",
    "external",
    "import-service",
    "repository-service"
  ],
  "quality_flags": [
    "estimated",
    "incomplete",
    "outlier",
    "imputed",
    "stale",
    "conflicting",
    "restricted",
    "unverified"
  ],
  "id_pattern": "^[a-z][a-z0-9._:-]{2,255}$",
  "extension_key_pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9-]+)+$",
  "source_checksum_pattern": "^sha256:[0-9a-f]{64}$",
  "legacy_contracts": [
    "catalyst-data-export/1.0",
    "catalyst-data-export/1.0.1",
    "unversioned-v1.0.x"
  ],
  "evidence_contract": "catalyst-data-evidence-chain/1.0",
  "evidence_roles": [
    "primary",
    "supporting",
    "conflicting",
    "derived",
    "contextual"
  ],
  "source_relationships": [
    "corroborates",
    "conflicts_with",
    "derived_from",
    "supersedes",
    "duplicates",
    "contextualizes"
  ],
  "provenance_event_types": [
    "record_created",
    "record_updated",
    "source_versioned",
    "source_snapshot_added",
    "source_linked",
    "source_unlinked",
    "transformed",
    "reviewed",
    "published",
    "corrected",
    "superseded",
    "imported"
  ],
  "evidence_gap_severities": [
    "info",
    "warning",
    "critical"
  ],
  "evidence_gap_codes": [
    "missing-source",
    "missing-citation",
    "missing-license",
    "missing-retrieval-date",
    "missing-checksum",
    "missing-method",
    "low-confidence",
    "conflicting-evidence",
    "restricted-source",
    "stale-source"
  ],
  "indicator_governance_contract": "catalyst-data-indicator-governance/1.0",
  "indicator_statuses": [
    "draft",
    "active",
    "deprecated",
    "replaced",
    "archived"
  ],
  "indicator_frequencies": [
    "continuous",
    "daily",
    "weekly",
    "monthly",
    "quarterly",
    "annual",
    "irregular",
    "event",
    "custom"
  ],
  "indicator_aggregations": [
    "sum",
    "mean",
    "median",
    "minimum",
    "maximum",
    "count",
    "ratio",
    "index",
    "point-estimate",
    "cumulative",
    "custom"
  ],
  "methodology_statuses": [
    "draft",
    "in-review",
    "approved",
    "deprecated",
    "archived"
  ],
  "framework_mapping_relationships": [
    "exactMatch",
    "closeMatch",
    "broaderMatch",
    "narrowerMatch",
    "relatedMatch"
  ],
  "comparability_statuses": [
    "equivalent",
    "convertible",
    "limited",
    "incompatible"
  ],
  "governance_event_types": [
    "indicator_registered",
    "indicator_versioned",
    "methodology_versioned",
    "unit_registered",
    "framework_mapped",
    "compatibility_rule_added"
  ],
  "observation_lineage_contract": "catalyst-data-observation-lineage/1.0",
  "question_types": [
    "research",
    "decision",
    "monitoring",
    "evaluation"
  ],
  "question_statuses": [
    "draft",
    "active",
    "answered",
    "archived"
  ],
  "instrument_types": [
    "survey",
    "sensor",
    "form",
    "api",
    "administrative",
    "model",
    "manual",
    "other"
  ],
  "dataset_access_levels": [
    "public",
    "internal",
    "restricted",
    "confidential"
  ],
  "observation_roles": [
    "baseline",
    "current",
    "supporting",
    "derived"
  ],
  "observation_quality_statuses": [
    "valid",
    "missing",
    "censored",
    "outlier",
    "imputed",
    "rejected"
  ],
  "lineage_event_types": [
    "question_linked",
    "instrument_versioned",
    "dataset_versioned",
    "batch_registered",
    "observation_recorded",
    "observation_linked",
    "transformation_recorded"
  ]
}
