{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-data-analysis-artifact-1.0.json",
  "title": "Catalyst Data Analysis Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_id", "workspace_id", "name", "analysis_type", "version", "inputs", "parameters", "environment", "code_reference", "outputs", "platform_links", "extensions"],
  "properties": {
    "schema_version": {"const": "catalyst-data-analysis-artifact/1.0"},
    "artifact_id": {"type": "string", "pattern": "^analysis:[A-Za-z0-9._:-]+$", "minLength": 10},
    "workspace_id": {"type": "string", "minLength": 1},
    "project_id": {"type": ["string", "null"]},
    "name": {"type": "string", "minLength": 1, "maxLength": 200},
    "description": {"type": ["string", "null"], "maxLength": 4000},
    "analysis_type": {"enum": ["analysis", "model", "scenario", "forecast", "sensitivity", "replication"]},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"},
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_ids", "roles"],
      "properties": {
        "record_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "roles": {"type": "object", "additionalProperties": {"enum": ["input", "baseline", "reference", "training", "validation", "comparison"]}}
      }
    },
    "parameters": {"type": "object"},
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime", "dependencies", "container", "hardware", "notes"],
      "properties": {
        "runtime": {"type": ["string", "null"]},
        "dependencies": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "container": {"type": ["string", "null"]},
        "hardware": {"type": ["string", "null"]},
        "notes": {"type": ["string", "null"]}
      }
    },
    "code_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "revision", "path", "entrypoint", "checksum"],
      "properties": {
        "repository": {"type": ["string", "null"]},
        "revision": {"type": ["string", "null"]},
        "path": {"type": ["string", "null"]},
        "entrypoint": {"type": ["string", "null"]},
        "checksum": {"type": ["string", "null"], "pattern": "^(sha256:[a-f0-9]{64})?$"}
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "output_type", "media_type", "description"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "output_type": {"enum": ["table", "figure", "model", "scenario", "forecast", "sensitivity", "document", "dataset", "metric", "log", "other"]},
          "media_type": {"type": "string", "minLength": 1},
          "description": {"type": ["string", "null"]}
        }
      }
    },
    "platform_links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["product", "capability", "external_artifact_id", "uri", "relation", "metadata"],
        "properties": {
          "product": {"enum": ["workbench", "research-lab", "catalyst-analytics-r", "decision-studio", "knowledge-library", "site-intelligence", "catalyst-canvas", "platform-core", "other"]},
          "capability": {"type": ["string", "null"]},
          "external_artifact_id": {"type": ["string", "null"]},
          "uri": {"type": ["string", "null"]},
          "relation": {"enum": ["produced-by", "consumed-by", "published-to", "reviewed-in", "related"]},
          "metadata": {"type": "object"}
        }
      }
    },
    "extensions": {
      "type": "object",
      "propertyNames": {"pattern": "^[a-z][a-z0-9.-]*:[A-Za-z0-9._-]+$"}
    }
  }
}
