{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-data-record-1.0.json",
  "title": "Catalyst Data Record 1.0",
  "description": "Canonical measurement record with review, quality, revisions, provenance, evidence, indicator governance, and observation lineage.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "record_id",
    "record_type",
    "created_at",
    "updated_at",
    "producer",
    "entity",
    "indicator",
    "period",
    "measurement",
    "source",
    "confidence",
    "review",
    "method",
    "extensions"
  ],
  "properties": {
    "$schema": {
      "const": "https://sustainablecatalyst.com/schemas/catalyst-data-record-1.0.json"
    },
    "schema_version": {
      "const": "catalyst-data-record/1.0"
    },
    "record_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
    },
    "record_type": {
      "enum": [
        "measurement"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "component"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "component": {
          "enum": [
            "python-engine",
            "browser-demo",
            "migration-tool",
            "external",
            "import-service",
            "repository-service",
            "connector-service"
          ]
        }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "type",
        "external_ids"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "country",
            "organization",
            "project",
            "program",
            "site",
            "policy",
            "persona",
            "experiment",
            "dataset",
            "other"
          ]
        },
        "external_ids": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9-]+)+$"
          },
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "indicator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "unit",
        "direction",
        "framework",
        "version"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "enum": [
            "higher",
            "lower",
            "neutral"
          ]
        },
        "framework": {
          "type": [
            "string",
            "null"
          ]
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "indicator_governance": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "https://sustainablecatalyst.com/schemas/catalyst-data-indicator-governance-1.0.json",
      "title": "Catalyst Data Indicator Governance 1.0",
      "description": "Versioned indicator definitions, units, methodologies, mappings, and comparability constraints.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "namespace",
        "code",
        "domain",
        "custodian",
        "status",
        "aliases",
        "definition",
        "frequency",
        "aggregation",
        "disaggregation_dimensions",
        "numerator",
        "denominator",
        "unit",
        "methodology",
        "framework_mappings",
        "compatibility"
      ],
      "properties": {
        "schema_version": {
          "const": "catalyst-data-indicator-governance/1.0"
        },
        "namespace": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9.-]{1,63}$"
        },
        "code": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{1,127}$"
        },
        "domain": {
          "type": "string",
          "minLength": 1
        },
        "custodian": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "draft",
            "active",
            "deprecated",
            "replaced",
            "archived"
          ]
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "definition": {
          "type": "string",
          "minLength": 1
        },
        "frequency": {
          "enum": [
            "continuous",
            "daily",
            "weekly",
            "monthly",
            "quarterly",
            "annual",
            "irregular",
            "event",
            "custom"
          ]
        },
        "aggregation": {
          "enum": [
            "sum",
            "mean",
            "median",
            "minimum",
            "maximum",
            "count",
            "ratio",
            "index",
            "point-estimate",
            "cumulative",
            "custom"
          ]
        },
        "disaggregation_dimensions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "numerator": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "required": [
            "name",
            "unit_id",
            "description"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "unit_id": {
              "type": [
                "string",
                "null"
              ],
              "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
            },
            "description": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "denominator": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "required": [
            "name",
            "unit_id",
            "description"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "unit_id": {
              "type": [
                "string",
                "null"
              ],
              "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
            },
            "description": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "unit": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "symbol",
            "name",
            "dimension",
            "canonical_unit_id",
            "conversion_factor",
            "conversion_offset"
          ],
          "properties": {
            "id": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
            },
            "symbol": {
              "type": "string",
              "minLength": 1
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "dimension": {
              "type": "string",
              "minLength": 1
            },
            "canonical_unit_id": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
            },
            "conversion_factor": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "conversion_offset": {
              "type": "number"
            }
          }
        },
        "methodology": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "version",
            "title",
            "description",
            "formula",
            "references",
            "status",
            "approved_by",
            "approved_at",
            "revision_notes"
          ],
          "properties": {
            "id": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
            },
            "version": {
              "type": "string",
              "minLength": 1
            },
            "title": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string"
            },
            "formula": {
              "type": [
                "string",
                "null"
              ]
            },
            "references": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "status": {
              "enum": [
                "draft",
                "in-review",
                "approved",
                "deprecated",
                "archived"
              ]
            },
            "approved_by": {
              "type": [
                "string",
                "null"
              ]
            },
            "approved_at": {
              "type": [
                "string",
                "null"
              ],
              "format": "date-time"
            },
            "revision_notes": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "framework_mappings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "framework",
              "code",
              "relationship",
              "notes"
            ],
            "properties": {
              "framework": {
                "type": "string",
                "minLength": 1
              },
              "code": {
                "type": "string",
                "minLength": 1
              },
              "relationship": {
                "enum": [
                  "exactMatch",
                  "closeMatch",
                  "broaderMatch",
                  "narrowerMatch",
                  "relatedMatch"
                ]
              },
              "notes": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        },
        "compatibility": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "comparable_versions",
            "required_dimensions",
            "methodology_equivalence",
            "notes"
          ],
          "properties": {
            "comparable_versions": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "required_dimensions": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "methodology_equivalence": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
              },
              "uniqueItems": true
            },
            "notes": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      }
    },
    "observation_lineage": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "https://sustainablecatalyst.com/schemas/catalyst-data-observation-lineage-1.0.json",
      "title": "Catalyst Data Observation Lineage 1.0",
      "description": "Research questions, collection instruments, dataset versions, observation batches, observations, and transformations linked to a governed measurement.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "questions",
        "instruments",
        "datasets",
        "batches",
        "observations",
        "transformations",
        "completeness_score"
      ],
      "properties": {
        "schema_version": {
          "const": "catalyst-data-observation-lineage/1.0"
        },
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "text",
              "type",
              "decision_context",
              "status",
              "owner"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
              },
              "text": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "enum": [
                  "research",
                  "decision",
                  "monitoring",
                  "evaluation"
                ]
              },
              "decision_context": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "status": {
                "enum": [
                  "draft",
                  "active",
                  "answered",
                  "archived"
                ]
              },
              "owner": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        },
        "instruments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "name",
              "type",
              "version",
              "description",
              "protocol",
              "provider",
              "calibration",
              "fields"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "enum": [
                  "survey",
                  "sensor",
                  "form",
                  "api",
                  "administrative",
                  "model",
                  "manual",
                  "other"
                ]
              },
              "version": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "protocol": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "provider": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "calibration": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "fields": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "name",
                    "data_type",
                    "unit_id",
                    "description"
                  ],
                  "properties": {
                    "name": {
                      "type": "string",
                      "minLength": 1
                    },
                    "data_type": {
                      "enum": [
                        "string",
                        "number",
                        "integer",
                        "boolean",
                        "date",
                        "datetime",
                        "object",
                        "array"
                      ]
                    },
                    "unit_id": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
                    },
                    "description": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "required": {
                      "type": "boolean"
                    },
                    "nullable": {
                      "type": "boolean"
                    }
                  },
                  "anyOf": [
                    {
                      "required": [
                        "required"
                      ]
                    },
                    {
                      "required": [
                        "nullable"
                      ]
                    }
                  ]
                }
              }
            }
          }
        },
        "datasets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "name",
              "version",
              "description",
              "license",
              "access",
              "checksum",
              "fields"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "license": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "access": {
                "enum": [
                  "public",
                  "internal",
                  "restricted",
                  "confidential"
                ]
              },
              "checksum": {
                "type": [
                  "string",
                  "null"
                ],
                "pattern": "^sha256:[0-9a-f]{64}$"
              },
              "fields": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "name",
                    "data_type",
                    "unit_id",
                    "description",
                    "nullable"
                  ],
                  "properties": {
                    "name": {
                      "type": "string",
                      "minLength": 1
                    },
                    "data_type": {
                      "enum": [
                        "string",
                        "number",
                        "integer",
                        "boolean",
                        "date",
                        "datetime",
                        "object",
                        "array"
                      ]
                    },
                    "unit_id": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
                    },
                    "description": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "nullable": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        },
        "batches": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "dataset_id",
              "instrument_id",
              "collected_at",
              "received_at",
              "collector",
              "protocol",
              "record_count",
              "notes"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
              },
              "dataset_id": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
              },
              "instrument_id": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
              },
              "collected_at": {
                "type": [
                  "string",
                  "null"
                ],
                "format": "date-time"
              },
              "received_at": {
                "type": [
                  "string",
                  "null"
                ],
                "format": "date-time"
              },
              "collector": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "protocol": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "record_count": {
                "type": "integer",
                "minimum": 0
              },
              "notes": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        },
        "observations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "batch_id",
              "role",
              "observed_at",
              "value",
              "value_text",
              "unit_id",
              "quality_status",
              "missing_reason",
              "censoring",
              "outlier",
              "imputation",
              "dimensions",
              "raw_payload"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
              },
              "batch_id": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
              },
              "role": {
                "enum": [
                  "baseline",
                  "current",
                  "supporting",
                  "derived"
                ]
              },
              "observed_at": {
                "type": [
                  "string",
                  "null"
                ],
                "format": "date-time"
              },
              "value": {
                "type": [
                  "number",
                  "null"
                ]
              },
              "value_text": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "unit_id": {
                "type": [
                  "string",
                  "null"
                ],
                "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
              },
              "quality_status": {
                "enum": [
                  "valid",
                  "missing",
                  "censored",
                  "outlier",
                  "imputed",
                  "rejected"
                ]
              },
              "missing_reason": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "censoring": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "outlier": {
                "type": "boolean"
              },
              "imputation": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "dimensions": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              },
              "raw_payload": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "transformations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "operation",
              "description",
              "software",
              "parameters",
              "input_observation_ids",
              "output_measurement_fields",
              "occurred_at"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
              },
              "operation": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "software": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "parameters": {
                "type": "object",
                "additionalProperties": true
              },
              "input_observation_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9._:-]{2,255}$"
                },
                "uniqueItems": true
              },
              "output_measurement_fields": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "uniqueItems": true
              },
              "occurred_at": {
                "type": [
                  "string",
                  "null"
                ],
                "format": "date-time"
              }
            }
          }
        },
        "completeness_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "review_workflow": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "https://sustainablecatalyst.com/schemas/catalyst-data-review-workflow-1.0.json",
      "title": "Catalyst Data Review Workflow 1.0",
      "description": "Human review states, quality assessments, publication gates, revision metadata, decisions, and comments.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "state",
        "priority",
        "assigned_reviewers",
        "quality",
        "publication_gate",
        "revision",
        "decisions",
        "comments"
